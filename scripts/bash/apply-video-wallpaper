#!/bin/bash
# Apply an animated video (MP4/WebM) wallpaper via mpvpaper, extract thumbnail, run matugen
. "$(dirname "$0")/lib.sh"
require_cmd jq ffmpeg mpvpaper

[ -z "$1" ] && exit 1
video_path="$1"
wall_dir=$(cfg_get '.paths.wallpaper')
matugen_scheme=$(cfg_get '.matugen.schemeType // "scheme-fidelity"')
kde_scheme=$(cfg_get '.matugen.kdeColorScheme // "SkwdMatugen"')
video_cache="$SKWD_CACHE/wallpaper/video-thumbs"

# Save wallpaper state for restore on next boot
echo '{"type":"video","path":"'"$video_path"'"}' > "$SKWD_CACHE/last-wallpaper.json"

# Clean up conflicting video daemons so they don't draw over each other
pkill -9 -f linux-wallpaperengine 2>/dev/null
pkill -x mpvpaper 2>/dev/null
rm -f "$wall_dir/lockscreen-video.mp4"

# Generate a thumbnail instantly for your UI and Matugen
video_name=$(basename "$video_path")
thumb_name="${video_name%.*}.jpg"
thumb_path="$video_cache/$thumb_name"
awww img "$thumb_path" --transition-type none

[ ! -f "$thumb_path" ] && { mkdir -p "$video_cache"; ffmpeg -y -ss 0 -i "$video_path" -vframes 1 -vf "scale=640:360:force_original_aspect_ratio=increase,crop=640:360" "$thumb_path" 2>/dev/null; }

# Launch the video on all monitors silently in the background
nohup mpvpaper -vs -o "no-audio loop=inf" '*' "$video_path" </dev/null >/dev/null 2>&1 &

# Propagate the extracted thumbnail colors to the system
if [ -f "$thumb_path" ]; then
  cp "$thumb_path" "$wall_dir/wallpaper.jpg"
  command -v matugen >/dev/null && matugen -c "$SKWD_MATUGEN_CONFIG" image -t "$matugen_scheme" --source-color-index 0 "$thumb_path"
  "$(dirname "$0")/apply-niri-colors"
  "$(dirname "$0")/generate-omp-theme"
fi